# Copy this file to mcpgit-runtime.env and replace the example values.
MCPGIT_REMOTE_BACKEND_ID=primary
MCPGIT_REMOTE_BACKEND_KIND=gitea
MCPGIT_REMOTE_BACKEND_WEB_BASE_URL=https://git.example.com
MCPGIT_REMOTE_BACKEND_API_BASE_URL=https://git.example.com/api/v1
MCPGIT_REMOTE_ORG=myorg
MCPGIT_REMOTE_CREDENTIAL_SOURCE=netrc
MCPGIT_BOOTSTRAP_REMOTE_REPOS=works,tablegit,binarygit,rootskills,mcpgitsystem,safegit
MCPGIT_REMOTE_STRESS_ALLOWED=false
